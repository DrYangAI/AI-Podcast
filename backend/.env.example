# ============================
# AI Podcast - API 密钥配置
# ============================
# 复制此文件为 .env 并填写你需要使用的模型 API Key
# 不需要的可以留空，只需配置你实际使用的模型即可

# ---- 国际模型 ----
AI_PODCAST_OPENAI_API_KEY=sk-...
AI_PODCAST_CLAUDE_API_KEY=sk-ant-...

# ---- 国产文本模型 ----
AI_PODCAST_DEEPSEEK_API_KEY=sk-...
AI_PODCAST_DOUBAO_API_KEY=                    # 火山引擎 ARK API Key
AI_PODCAST_QWEN_API_KEY=sk-...                # 阿里云 DashScope API Key
AI_PODCAST_ZHIPU_API_KEY=                     # 智谱 BigModel API Key
AI_PODCAST_MINIMAX_API_KEY=                   # MiniMax 海螺 API Key
AI_PODCAST_WENXIN_API_KEY=                    # 百度千帆 Bearer Token
AI_PODCAST_MOONSHOT_API_KEY=sk-...            # 月之暗面 Kimi API Key
AI_PODCAST_STEPFUN_API_KEY=                   # 阶跃星辰 API Key
AI_PODCAST_SILICONFLOW_API_KEY=sk-...         # 硅基流动 API Key

# ---- 国产图片模型 ----
# 豆包 Seedream: 复用 DOUBAO_API_KEY (火山引擎 ARK)
# 智谱 CogView: 复用 ZHIPU_API_KEY
# 通义万相: 复用 QWEN_API_KEY (DashScope)
# MiniMax 图片: 复用 MINIMAX_API_KEY

# ---- 国产视频模型 ----
# 豆包 Seedance: 复用 DOUBAO_API_KEY (火山引擎 ARK)
# 智谱 CogVideoX: 复用 ZHIPU_API_KEY

# ---- TTS 语音合成 ----
# OpenAI TTS: 复用 OPENAI_API_KEY
# MiniMax TTS: 复用 MINIMAX_API_KEY
# 豆包 TTS: 复用 DOUBAO_API_KEY (火山引擎 ARK)
# 通义语音 CosyVoice: 复用 QWEN_API_KEY (DashScope)
AI_PODCAST_ELEVENLABS_API_KEY=                # ElevenLabs API Key

# ---- 讯飞语音合成 (需要三个凭证) ----
AI_PODCAST_XUNFEI_APP_ID=
AI_PODCAST_XUNFEI_API_KEY=
AI_PODCAST_XUNFEI_API_SECRET=
